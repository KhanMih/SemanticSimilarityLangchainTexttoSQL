# ── LLM / Embeddings ──────────────────────────────────────
GOOGLE_API_KEY=AIza...

# ── PostgreSQL (business database you query against) ──────
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/semantic_sql

# ── pgvector store (can be same DB, different schema) ─────
VECTOR_STORE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/semantic_sql

# ── Langfuse ──────────────────────────────────────────────
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com
# For self-hosted: LANGFUSE_HOST=http://localhost:3000

# ── Agent Defaults ────────────────────────────────────────
DEFAULT_LLM_MODEL=gpt-4o-mini
DEFAULT_EMBEDDING_MODEL=text-embedding-3-small
FEW_SHOT_K=3
MAX_PROMPT_TOKENS=3500
SIMILARITY_DEDUP_THRESHOLD=0.95
SQL_EXECUTION_TIMEOUT=30
